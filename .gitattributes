# Auto normalize line endings to LF for all text files
* text eol=lf

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files - use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Config and markup files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files - should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.elf binary
*.axf binary
*.o binary
*.a binary
*.lib binary
*.exe binary
*.zip binary
*.gz binary
*.tar binary

# Project-specific binary extensions
*.map binary diff=binary
